# Sample Environment Variables for Backend
NODE_ENV=development
PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/jagannath_darshan?appName=Cluster0

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cloud Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin Credentials
ADMIN_EMAIL=admin@jagannathdarshanyatra.com
ADMIN_PASSWORD=your_admin_password
SUPER_ADMIN_EMAIL=superadmin@jagannathdarshanyatra.com
SUPER_ADMIN_PASSWORD=your_super_admin_password
